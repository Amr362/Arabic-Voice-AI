# ═══════════════════════════════════════════════════════════════
#  ArabVoice AI — Environment Variables
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Database (Railway Postgres) ──────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/arabvoice

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://ivkrbmogcnrxartnreit.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUDIO_BUCKET=generated-audio

# ── Hugging Face (kept on backend ONLY — never expose to frontend) ──
HF_TOKEN=

# ── Egyptian Voice (optional — default HF sample used if not set) ──
EGYPTIAN_SPEAKER_URL=https://your-cdn.com/egyptian-speaker-sample.wav

# ── Railway Edge-TTS service URL ─────────────────────────────
# (deploy the edge-tts microservice separately on Railway)
RAILWAY_TTS_URL=https://edge-tts-production-xxxx.up.railway.app/tts

# ── Frontend (Vite env vars — safe to expose) ─────────────────
VITE_SUPABASE_URL=https://ivkrbmogcnrxartnreit.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_BASE_URL=https://your-api.up.railway.app

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
